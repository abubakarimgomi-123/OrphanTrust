@model OrphanTrust.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewBag.Title = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center align-items-center"
         style="min-height: calc(100vh - 120px);">
        <div class="col-md-5 col-lg-4">

            <div class="text-center mb-4">
                <div style="width:70px;height:70px;border-radius:50%;
                            background:#FF8F00;display:flex;
                            align-items:center;justify-content:center;
                            margin:0 auto 1rem;">
                    <i class="bi bi-key-fill text-white" style="font-size:2rem;"></i>
                </div>
                <h4 class="fw-bold" style="color:#1B5E20;">Forgot Password?</h4>
                <p class="text-muted small">
                    Enter your email and we'll send you a reset link
                </p>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-4">

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2">
                            @Html.ValidationSummary(true, "",
                                new { @class = "mb-0" })
                        </div>
                    }

                    @using (Html.BeginForm("ForgotPassword", "Account",
                        FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            @Html.LabelFor(m => m.Email,
                                new { @class = "form-label fw-medium" })
                            @Html.TextBoxFor(m => m.Email,
                                new
                                     {
                                    @class = "form-control",
                                    placeholder = "Enter your registered email",
                                    type = "email"
                                })
                            @Html.ValidationMessageFor(m => m.Email,
                                "", new { @class = "text-danger small" })
                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100 py-2 fw-semibold">
                            <i class="bi bi-envelope me-2"></i>
                            Send Reset Link
                        </button>
                    }
                </div>
            </div>

            <div class="text-center mt-3">
                <a href="@Url.Action("Login","Account")"
                   class="small text-decoration-none"
                   style="color:#2E7D32;">
                    <i class="bi bi-arrow-left me-1"></i>Back to Login
                </a>
            </div>

        </div>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
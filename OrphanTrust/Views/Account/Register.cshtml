@model OrphanTrust.ViewModels.Account.RegisterViewModel
@{
    ViewBag.Title = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center align-items-center"
         style="min-height: calc(100vh - 120px);">
        <div class="col-md-6 col-lg-5">

            <!-- Header -->
            <div class="text-center mb-4">
                <div style="width:70px;height:70px;border-radius:50%;
                            background:#2E7D32;display:flex;
                            align-items:center;justify-content:center;
                            margin:0 auto 1rem;">
                    <i class="bi bi-person-plus-fill text-white"
                       style="font-size:2rem;"></i>
                </div>
                <h4 class="fw-bold" style="color:#1B5E20;">
                    Join OrphanTrust
                </h4>
                <p class="text-muted small">
                    Create an account to start making a difference
                </p>
            </div>

            <!-- Card -->
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-4" style="color:#2E7D32;">
                        <i class="bi bi-person-plus me-2"></i>Create Account
                    </h5>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2">
                            <i class="bi bi-exclamation-circle me-2"></i>
                            @Html.ValidationSummary(true, "",
                                new { @class = "mb-0" })
                        </div>
                    }

                    @using (Html.BeginForm("Register", "Account",
                        FormMethod.Post, new { @class = "needs-validation" }))
                    {
                        @Html.AntiForgeryToken()

                        <!-- Full Name -->
                        <div class="mb-3">
                            @Html.LabelFor(m => m.FullName,
                                new { @class = "form-label fw-medium" })
                            @Html.TextBoxFor(m => m.FullName,
                                new
                                     {
                                    @class = "form-control",
                                    placeholder = "Enter your full name"
                                })
                            @Html.ValidationMessageFor(m => m.FullName,
                                "", new { @class = "text-danger small" })
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            @Html.LabelFor(m => m.Email,
                                new { @class = "form-label fw-medium" })
                            @Html.TextBoxFor(m => m.Email,
                                new
                                     {
                                    @class = "form-control",
                                    placeholder = "Enter your email",
                                    type = "email"
                                })
                            @Html.ValidationMessageFor(m => m.Email,
                                "", new { @class = "text-danger small" })
                        </div>

                        <!-- Region -->
                        <div class="mb-3">
                            @Html.LabelFor(m => m.Region,
                                new { @class = "form-label fw-medium" })
                            @Html.DropDownListFor(m => m.Region,
                                new SelectList(new[] {
                                    "Dar es Salaam","Dodoma","Mwanza",
                                    "Arusha","Mbeya","Morogoro","Tanga",
                                    "Zanzibar","Kilimanjaro","Kigoma",
                                    "Tabora","Ruvuma","Iringa","Mara",
                                    "Shinyanga","Kagera","Lindi","Mtwara",
                                    "Singida","Rukwa","Katavi","Njombe",
                                    "Simiyu","Geita","Songwe"
                                }),
                                "-- Select your region --",
                                new { @class = "form-select" })
                            @Html.ValidationMessageFor(m => m.Region,
                                "", new { @class = "text-danger small" })
                        </div>

                        <!-- Register As -->
                        <div class="mb-3">
                            @Html.LabelFor(m => m.Role,
                                "Register as",
                                new { @class = "form-label fw-medium" })
                            @Html.DropDownListFor(m => m.Role,
                                new SelectList(new[] {
                                    new { Value = "Donor",
                                          Text  = "Donor — I want to donate" }
                                }, "Value", "Text"),
                                new { @class = "form-select" })
                        </div>

                        <!-- Password -->
                        <div class="mb-3">
                            @Html.LabelFor(m => m.Password,
                                new { @class = "form-label fw-medium" })
                            <div class="input-group">
                                @Html.PasswordFor(m => m.Password,
                                    new
                                         {
                                        @class = "form-control",
                                        placeholder = "Min 8 chars, upper, lower, number, symbol",
                                        id = "passwordInput"
                                    })
                                <button class="btn btn-outline-secondary"
                                        type="button"
                                        onclick="togglePassword('passwordInput','eye1')">
                                    <i class="bi bi-eye" id="eye1"></i>
                                </button>
                            </div>
                            @Html.ValidationMessageFor(m => m.Password,
                                "", new { @class = "text-danger small" })
                        </div>

                        <!-- Confirm Password -->
                        <div class="mb-4">
                            @Html.LabelFor(m => m.ConfirmPassword,
                                new { @class = "form-label fw-medium" })
                            <div class="input-group">
                                @Html.PasswordFor(m => m.ConfirmPassword,
                                    new
                                         {
                                        @class = "form-control",
                                        placeholder = "Repeat your password",
                                        id = "confirmInput"
                                    })
                                <button class="btn btn-outline-secondary"
                                        type="button"
                                        onclick="togglePassword('confirmInput','eye2')">
                                    <i class="bi bi-eye" id="eye2"></i>
                                </button>
                            </div>
                            @Html.ValidationMessageFor(m => m.ConfirmPassword,
                                "", new { @class = "text-danger small" })
                        </div>

                        <!-- Password strength hints -->
                        <div class="mb-3 p-3 rounded"
                             style="background:#f1f8f1;border:1px solid #c8e6c9;">
                            <small class="text-muted d-block mb-1 fw-medium">
                                Password must contain:
                            </small>
                            <small class="text-muted">
                                <i class="bi bi-check-circle-fill text-success me-1"></i>
                                At least 8 characters<br />
                                <i class="bi bi-check-circle-fill text-success me-1"></i>
                                Uppercase &amp; lowercase letters<br />
                                <i class="bi bi-check-circle-fill text-success me-1"></i>
                                At least one number<br />
                                <i class="bi bi-check-circle-fill text-success me-1"></i>
                                At least one special character
                            </small>
                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100 py-2 fw-semibold">
                            <i class="bi bi-person-check me-2"></i>
                            Create Account
                        </button>
                    }
                </div>
            </div>

            <!-- Login link -->
            <div class="text-center mt-3">
                <span class="text-muted small">Already have an account?</span>
                <a href="@Url.Action("Login","Account")"
                   class="small fw-semibold ms-1 text-decoration-none"
                   style="color:#2E7D32;">
                    Sign in here
                </a>
            </div>

        </div>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        function togglePassword(inputId, iconId) {
            var input = document.getElementById(inputId);
            var icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type    = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type    = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}
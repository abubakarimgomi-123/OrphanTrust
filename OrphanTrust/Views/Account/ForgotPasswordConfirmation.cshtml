@{
    ViewBag.Title = "Check Your Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center align-items-center"
         style="min-height: calc(100vh - 120px);">
        <div class="col-md-5 col-lg-4">

            <div class="card shadow-sm text-center">
                <div class="card-body p-5">

                    <div style="width:80px;height:80px;border-radius:50%;
                                background:#E8F5E9;display:flex;
                                align-items:center;justify-content:center;
                                margin:0 auto 1.5rem;">
                        <i class="bi bi-envelope-check-fill"
                           style="font-size:2.5rem;color:#2E7D32;"></i>
                    </div>

                    <h4 class="fw-bold mb-2" style="color:#1B5E20;">
                        Check Your Email
                    </h4>
                    <p class="text-muted mb-4">
                        If an account with that email exists, we've sent
                        a password reset link. Please check your inbox
                        and spam folder.
                    </p>

                    <div class="alert alert-info py-2 text-start small">
                        <i class="bi bi-info-circle me-2"></i>
                        The reset link expires in <strong>24 hours</strong>.
                    </div>

                    <a href="@Url.Action("Login","Account")"
                       class="btn btn-primary w-100 py-2 mt-2 fw-semibold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        Back to Login
                    </a>

                </div>
            </div>

        </div>
    </div>
</div>
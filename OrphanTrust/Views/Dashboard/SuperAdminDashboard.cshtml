@{
    ViewBag.Title = "Super Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-speedometer2 me-2"></i>Super Admin Dashboard</h2>
        <p class="text-muted mb-0 small">
            Welcome back — here's your system overview
        </p>
    </div>
    <div class="text-muted small">
        <i class="bi bi-calendar me-1"></i>
        @DateTime.Now.ToString("dddd, MMMM dd yyyy")
    </div>
</div>

<!-- Stat Cards Row 1 -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="stat-card"
             style="background:linear-gradient(135deg,#2E7D32,#43A047);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Total Orphanages</div>
                    <div class="stat-number">@ViewBag.TotalOrphanages</div>
                </div>
                <i class="bi bi-house-heart-fill"
                   style="font-size:2.5rem;opacity:0.3;"></i>
            </div>
            <div class="mt-2" style="font-size:0.8rem;opacity:0.8;">
                <i class="bi bi-clock me-1"></i>
                @ViewBag.PendingOrphanages pending approval
            </div>
        </div>
    </div>

    <div class="col-md-3 col-sm-6">
        <div class="stat-card"
             style="background:linear-gradient(135deg,#1565C0,#1976D2);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Total Children</div>
                    <div class="stat-number">@ViewBag.TotalChildren</div>
                </div>
                <i class="bi bi-person-hearts"
                   style="font-size:2.5rem;opacity:0.3;"></i>
            </div>
            <div class="mt-2" style="font-size:0.8rem;opacity:0.8;">
                <i class="bi bi-heart me-1"></i>
                Across all orphanages
            </div>
        </div>
    </div>

    <div class="col-md-3 col-sm-6">
        <div class="stat-card"
             style="background:linear-gradient(135deg,#E65100,#F57C00);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Total Donations</div>
                    <div class="stat-number">@ViewBag.TotalDonations</div>
                </div>
                <i class="bi bi-cash-coin"
                   style="font-size:2.5rem;opacity:0.3;"></i>
            </div>
            <div class="mt-2" style="font-size:0.8rem;opacity:0.8;">
                <i class="bi bi-currency-exchange me-1"></i>
                TZS @String.Format("{0:N0}", ViewBag.TotalAmountRaised) raised
            </div>
        </div>
    </div>

    <div class="col-md-3 col-sm-6">
        <div class="stat-card"
             style="background:linear-gradient(135deg,#6A1B9A,#8E24AA);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Total Users</div>
                    <div class="stat-number">@ViewBag.TotalUsers</div>
                </div>
                <i class="bi bi-people-fill"
                   style="font-size:2.5rem;opacity:0.3;"></i>
            </div>
            <div class="mt-2" style="font-size:0.8rem;opacity:0.8;">
                <i class="bi bi-person-check me-1"></i>
                Registered on platform
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header py-3">
                <i class="bi bi-lightning-fill me-2 text-warning"></i>
                Quick Actions
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-2 col-sm-4 col-6">
                        <a href="@Url.Action("Create","Orphanages")"
                           class="btn btn-outline-success w-100 py-3 d-flex
                                  flex-column align-items-center gap-1">
                            <i class="bi bi-plus-circle" style="font-size:1.5rem;"></i>
                            <small>Add Orphanage</small>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4 col-6">
                        <a href="@Url.Action("Index","Users")"
                           class="btn btn-outline-primary w-100 py-3 d-flex
                                  flex-column align-items-center gap-1">
                            <i class="bi bi-people" style="font-size:1.5rem;"></i>
                            <small>Manage Users</small>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4 col-6">
                        <a href="@Url.Action("Index","Donations")"
                           class="btn btn-outline-warning w-100 py-3 d-flex
                                  flex-column align-items-center gap-1">
                            <i class="bi bi-cash-coin" style="font-size:1.5rem;"></i>
                            <small>View Donations</small>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4 col-6">
                        <a href="@Url.Action("Index","Distributions")"
                           class="btn btn-outline-info w-100 py-3 d-flex
                                  flex-column align-items-center gap-1">
                            <i class="bi bi-send-check" style="font-size:1.5rem;"></i>
                            <small>Distributions</small>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4 col-6">
                        <a href="@Url.Action("Index","AuditLogs")"
                           class="btn btn-outline-secondary w-100 py-3 d-flex
                                  flex-column align-items-center gap-1">
                            <i class="bi bi-journal-text" style="font-size:1.5rem;"></i>
                            <small>Audit Logs</small>
                        </a>
                    </div>
                    <div class="col-md-2 col-sm-4 col-6">
                        <a href="@Url.Action("Index","Blockchain")"
                           class="btn btn-outline-dark w-100 py-3 d-flex
                                  flex-column align-items-center gap-1">
                            <i class="bi bi-link-45deg" style="font-size:1.5rem;"></i>
                            <small>Blockchain</small>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Pending Approvals Alert -->
@if (ViewBag.PendingOrphanages > 0)
{
    <div class="alert alert-warning d-flex align-items-center gap-3 mb-4">
        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
        <div>
            <strong>@ViewBag.PendingOrphanages orphanage(s) pending approval.</strong>
            <a href="@Url.Action("Pending","Orphanages")"
               class="ms-2 alert-link">
                Review now →
            </a>
        </div>
    </div>
}

<!-- System Status -->
<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header py-3">
                <i class="bi bi-activity me-2 text-success"></i>
                System Status
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center
                            py-2 border-bottom">
                    <span class="small">Database</span>
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i>Online
                    </span>
                </div>
                <div class="d-flex justify-content-between align-items-center
                            py-2 border-bottom">
                    <span class="small">Authentication</span>
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i>Active
                    </span>
                </div>
                <div class="d-flex justify-content-between align-items-center
                            py-2 border-bottom">
                    <span class="small">Blockchain (Avalanche Fuji)</span>
                    <span class="badge bg-warning text-dark">
                        <i class="bi bi-clock me-1"></i>Testnet
                    </span>
                </div>
                <div class="d-flex justify-content-between align-items-center
                            py-2">
                    <span class="small">Email Service</span>
                    <span class="badge bg-secondary">
                        <i class="bi bi-envelope me-1"></i>Configured
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header py-3">
                <i class="bi bi-info-circle me-2 text-info"></i>
                Platform Info
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="small text-muted">Platform</span>
                    <span class="small fw-medium">OrphanTrust v1.0</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="small text-muted">Framework</span>
                    <span class="small fw-medium">ASP.NET MVC 5</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="small text-muted">Blockchain</span>
                    <span class="small fw-medium">Avalanche Fuji Testnet</span>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span class="small text-muted">Deployed for</span>
                    <span class="small fw-medium">Tanzania Orphanages</span>
                </div>
            </div>
        </div>
    </div>
</div>
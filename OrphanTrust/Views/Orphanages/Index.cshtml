@model IEnumerable<OrphanTrust.Models.DomainModels.Orphanage>
@{
    ViewBag.Title = "Orphanages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-house-heart me-2"></i>Orphanages</h2>
        <p class="text-muted mb-0 small">All registered orphanages</p>
    </div>
    @if (Session["UserRole"] != null &&
         Session["UserRole"].ToString() == "SuperAdmin")
    {
        <a href="@Url.Action("Create","Orphanages")"
           class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add Orphanage
        </a>
    }
</div>

@if (Model != null && Model.Any())
{
    <div class="row g-3">
        @foreach (var o in Model)
        {
            <div class="col-md-4">
                <div class="card h-100">
                    <div style="height:80px;background:linear-gradient(
                                135deg,#2E7D32,#43A047);
                                border-radius:12px 12px 0 0;
                                display:flex;align-items:center;
                                justify-content:center;">
                        <i class="bi bi-house-heart-fill text-white"
                           style="font-size:2rem;opacity:0.7;"></i>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <h6 class="fw-bold mb-0">@o.Name</h6>
                            @{
                                var badge = o.Status == "Active"
                                    ? "bg-success"
                                    : o.Status == "Pending"
                                        ? "bg-warning text-dark"
                                        : "bg-danger";
                            }
                            <span class="badge @badge">@o.Status</span>
                        </div>
                        <div class="text-muted small mb-1">
                            <i class="bi bi-geo-alt me-1"></i>@o.Region
                        </div>
                        <div class="text-muted small mb-2">
                            <i class="bi bi-hash me-1"></i>
                            @o.RegistrationNumber
                        </div>
                        @if (o.IsVerifiedOnChain)
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-shield-check me-1"></i>
                                Blockchain Verified
                            </span>
                        }
                    </div>
                    <div class="card-footer bg-white border-top-0">
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("Details","Orphanages",
                                       new { id = o.OrphanageId })"
                               class="btn btn-outline-success btn-sm flex-fill">
                                <i class="bi bi-eye me-1"></i>View
                            </a>
                            @if (Session["UserRole"] != null &&
                                 Session["UserRole"].ToString() == "SuperAdmin")
                            {
                                <a href="@Url.Action("Edit","Orphanages",
                                           new { id = o.OrphanageId })"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post"
                                      action="@Url.Action("Verify","Orphanages",
                                                new { id = o.OrphanageId })"
                                      style="display:inline;">
                                    <button type="submit"
                                            class="btn btn-outline-warning btn-sm"
                                            title="Verify on Blockchain">
                                        <i class="bi bi-shield-check"></i>
                                    </button>
                                </form>
                                <form method="post"
                                      action="@Url.Action("Delete","Orphanages",
                                                new { id = o.OrphanageId })"
                                      style="display:inline;"
                                      onsubmit="return confirm('Delete this orphanage?')">
                                    <button type="submit"
                                            class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-house-heart"
           style="font-size:4rem;color:#c8e6c9;"></i>
        <p class="text-muted mt-3">No orphanages registered yet.</p>
        @if (Session["UserRole"] != null &&
             Session["UserRole"].ToString() == "SuperAdmin")
        {
            <a href="@Url.Action("Create","Orphanages")"
               class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Add First Orphanage
            </a>
        }
    </div>
}
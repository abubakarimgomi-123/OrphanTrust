@model OrphanTrust.Models.DomainModels.Orphanage
@{
    ViewBag.Title = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-house-heart me-2"></i>@Model.Name</h2>
        <p class="text-muted mb-0 small">
            <i class="bi bi-geo-alt me-1"></i>@Model.Region
        </p>
    </div>
    <div class="d-flex gap-2">
        @if (Model.IsVerifiedOnChain)
        {
            <span class="badge bg-success fs-6 px-3 py-2">
                <i class="bi bi-shield-check me-1"></i>
                Blockchain Verified
            </span>
        }
        @if (Session["UserRole"] != null &&
             Session["UserRole"].ToString() == "SuperAdmin")
        {
            <a href="@Url.Action("Edit","Orphanages",
                       new { id = Model.OrphanageId })"
               class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
        }
        <a href="@Url.Action("Index","Orphanages")"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header py-3">
                <i class="bi bi-info-circle me-2 text-success"></i>
                Orphanage Information
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">Name</div>
                        <div class="fw-medium">@Model.Name</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">Region</div>
                        <div class="fw-medium">@Model.Region</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">
                            Registration Number
                        </div>
                        <div class="fw-medium">@Model.RegistrationNumber</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">Status</div>
                        @{
                            var badge = Model.Status == "Active"
                                ? "bg-success"
                                : Model.Status == "Pending"
                                    ? "bg-warning text-dark"
                                    : "bg-danger";
                        }
                        <span class="badge @badge">@Model.Status</span>
                    </div>
                    <div class="col-md-12">
                        <div class="text-muted small mb-1">Address</div>
                        <div class="fw-medium">@Model.Address</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ContactPhone))
                    {
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Phone</div>
                            <div class="fw-medium">@Model.ContactPhone</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ContactEmail))
                    {
                        <div class="col-md-6">
                            <div class="text-muted small mb-1">Email</div>
                            <div class="fw-medium">@Model.ContactEmail</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="col-md-12">
                            <div class="text-muted small mb-1">Description</div>
                            <div>@Model.Description</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Donate button -->
        @if (Session["UserRole"] != null &&
             Session["UserRole"].ToString() == "Donor")
        {
            <div class="card"
                 style="background:linear-gradient(135deg,#2E7D32,#43A047);
                        color:#fff;">
                <div class="card-body text-center py-4">
                    <h5 class="fw-bold mb-2">Support This Orphanage</h5>
                    <p class="mb-3" style="opacity:0.9;">
                        Your donation will be recorded on the
                        Avalanche blockchain
                    </p>
                    <a href="@Url.Action("Create","Donations",
                               new { orphanageId = Model.OrphanageId })"
                       class="btn btn-warning btn-lg px-5 fw-semibold">
                        <i class="bi bi-heart me-2"></i>Donate Now
                    </a>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        <!-- Blockchain Info -->
        <div class="card mb-3">
            <div class="card-header py-3">
                <i class="bi bi-link-45deg me-2"></i>Blockchain Status
            </div>
            <div class="card-body">
                @if (Model.IsVerifiedOnChain)
                {
                    <div class="text-center py-2">
                        <i class="bi bi-shield-check-fill text-success"
                           style="font-size:3rem;"></i>
                        <div class="fw-bold text-success mt-2">
                            Verified on Chain
                        </div>
                        @if (Model.VerifiedAt.HasValue)
                        {
                            <div class="text-muted small mt-1">
                                @Model.VerifiedAt.Value.ToString("MMM dd, yyyy")
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.BlockchainAddress))
                        {
                            <div class="mt-2">
                                <small class="text-muted">
                                    Contract: @Model.BlockchainAddress
                                </small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-2">
                        <i class="bi bi-shield-x text-muted"
                           style="font-size:3rem;"></i>
                        <div class="text-muted mt-2">
                            Not yet verified on blockchain
                        </div>
                        @if (Session["UserRole"] != null &&
                             Session["UserRole"].ToString() == "SuperAdmin")
                        {
                            <form method="post"
                                  action="@Url.Action("Verify","Orphanages",
                                            new { id = Model.OrphanageId })"
                                  class="mt-3">
                                <button type="submit"
                                        class="btn btn-warning btn-sm">
                                    <i class="bi bi-shield-check me-1"></i>
                                    Verify on Blockchain
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Stats -->
        <div class="card">
            <div class="card-header py-3">
                <i class="bi bi-bar-chart me-2"></i>Statistics
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between py-2
                            border-bottom">
                    <span class="text-muted small">Children</span>
                    <span class="fw-bold">
                        @Model.Children.Count
                    </span>
                </div>
                <div class="d-flex justify-content-between py-2
                            border-bottom">
                    <span class="text-muted small">Donations</span>
                    <span class="fw-bold">
                        @Model.Donations.Count
                    </span>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span class="text-muted small">Open Needs</span>
                    <span class="fw-bold">
                        @Model.Needs.Count(n => n.Status == "Open")
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>
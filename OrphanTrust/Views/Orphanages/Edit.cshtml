@model OrphanTrust.Models.DomainModels.Orphanage
@{
    ViewBag.Title = "Edit Orphanage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h2><i class="bi bi-pencil me-2"></i>Edit Orphanage</h2>
    <p class="text-muted mb-0 small">Update orphanage information</p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header py-3">
                <i class="bi bi-house-heart me-2 text-success"></i>
                @Model.Name
            </div>
            <div class="card-body p-4">

                @using (Html.BeginForm("Edit", "Orphanages", FormMethod.Post))
                {
                    @Html.HiddenFor(m => m.OrphanageId)

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-medium">
                                Orphanage Name <span class="text-danger">*</span>
                            </label>
                            @Html.TextBoxFor(m => m.Name,
                                new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.Name,
                                "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-medium">Region</label>
                            @Html.DropDownListFor(m => m.Region,
                                new SelectList(new[] {
                                    "Dar es Salaam","Dodoma","Mwanza",
                                    "Arusha","Mbeya","Morogoro","Tanga",
                                    "Zanzibar","Kilimanjaro","Kigoma",
                                    "Tabora","Ruvuma","Iringa","Mara",
                                    "Shinyanga","Kagera","Lindi","Mtwara",
                                    "Singida","Rukwa","Katavi","Njombe",
                                    "Simiyu","Geita","Songwe"
                                }, Model.Region),
                                "-- Select Region --",
                                new { @class = "form-select" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-medium">
                                Registration Number
                            </label>
                            @Html.TextBoxFor(m => m.RegistrationNumber,
                                new { @class = "form-control" })
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-medium">Address</label>
                            @Html.TextBoxFor(m => m.Address,
                                new { @class = "form-control" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-medium">Phone</label>
                            @Html.TextBoxFor(m => m.ContactPhone,
                                new { @class = "form-control" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-medium">Email</label>
                            @Html.TextBoxFor(m => m.ContactEmail,
                                new { @class = "form-control", type = "email" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-medium">Status</label>
                            @Html.DropDownListFor(m => m.Status,
                                new SelectList(new[] {
                                    "Pending","Active","Suspended","Rejected"
                                }, Model.Status),
                                new { @class = "form-select" })
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-medium">
                                Description
                            </label>
                            @Html.TextAreaFor(m => m.Description,
                                new { @class = "form-control", rows = "3" })
                        </div>

                        <div class="col-md-12 mt-2">
                            <div class="d-flex gap-2">
                                <button type="submit"
                                        class="btn btn-primary px-4">
                                    <i class="bi bi-check-circle me-2"></i>
                                    Save Changes
                                </button>
                                <a href="@Url.Action("Index","Orphanages")"
                                   class="btn btn-outline-secondary px-4">
                                    <i class="bi bi-arrow-left me-2"></i>
                                    Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
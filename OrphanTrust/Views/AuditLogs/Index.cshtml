@model IEnumerable<OrphanTrust.Models.DomainModels.AuditLog>
@{
    ViewBag.Title = "Audit Logs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h2><i class="bi bi-journal-text me-2"></i>Audit Logs</h2>
    <p class="text-muted mb-0 small">
        System activity log — last 200 entries
    </p>
</div>

@if (Model != null && Model.Any())
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background:#f8fdf8;">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Entity</th>
                            <th>IP Address</th>
                            <th>Timestamp</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td class="ps-4">#@log.LogId</td>
                                <td class="small">
                                    @(log.UserEmail ?? "System")
                                </td>
                                <td>
                                    @{
                                        var actionBadge =
                                            log.Action == "Login"
                                                ? "bg-success"
                                                : log.Action == "Register"
                                                    ? "bg-primary"
                                                    : "bg-secondary";
                                    }
                                    <span class="badge @actionBadge">
                                        @log.Action
                                    </span>
                                </td>
                                <td class="small">@log.Entity</td>
                                <td class="small text-muted">
                                    @log.IpAddress
                                </td>
                                <td class="small text-muted">
                                    @log.Timestamp.ToString(
                                        "MMM dd, yyyy HH:mm")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-journal-text"
           style="font-size:4rem;color:#c8e6c9;"></i>
        <p class="text-muted mt-3">No audit logs yet.</p>
    </div>
}
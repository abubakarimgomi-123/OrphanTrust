@model IEnumerable<OrphanTrust.Models.DomainModels.ApplicationUser>
@{
    ViewBag.Title = "Users";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h2><i class="bi bi-people me-2"></i>Users</h2>
    <p class="text-muted mb-0 small">All registered users</p>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead style="background:#f8fdf8;">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Region</th>
                        <th>Status</th>
                        <th>Joined</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td class="ps-4">#@u.Id</td>
                            <td class="fw-medium">@u.FullName</td>
                            <td>@u.Email</td>
                            <td>@u.Region</td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td class="text-muted small">
                                @u.CreatedAt.ToString("MMM dd, yyyy")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
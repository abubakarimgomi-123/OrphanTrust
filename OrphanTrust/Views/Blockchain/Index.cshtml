@{
    ViewBag.Title = "Blockchain Logs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h2><i class="bi bi-link-45deg me-2"></i>Blockchain Logs</h2>
    <p class="text-muted mb-0 small">
        All transactions recorded on Avalanche Fuji Testnet
    </p>
</div>

<div class="text-center py-5">
    <i class="bi bi-link-45deg"
       style="font-size:4rem;color:#c8e6c9;"></i>
    <p class="text-muted mt-3">Blockchain transactions appear here.</p>
    <a href="@Url.Action("Verify","Blockchain")"
       class="btn btn-primary">
        <i class="bi bi-search me-2"></i>Verify a Transaction
    </a>
</div>